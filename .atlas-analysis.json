  "keyFeatures": [
    "Rust-powered CLI with memory safety and minimal binary size",
    "Interactive REPL shell with slash command support",
    "One-shot prompt mode for non-interactive use",
    "Multi-provider support: Anthropic, OpenAI-compatible, xAI/Grok",
    "Built-in tool suite: bash, file read/write/edit, glob, grep, web fetch/search",
    "Session persistence and resumable conversations via JSON state",
    "MCP (Model Context Protocol) server integration",
    "Plugin system for extending tools and functionality",
    "Skills system for loading local SKILL.md instruction files",
    "Agent spawning for parallel sub-agent task delegation",
    "OAuth authentication flow with credential persistence",
    "Workspace-aware CLAW.md discovery for project context",
    "Git integration: branch, worktree, commit, PR workflows",
    "Configurable permission modes: read-only, workspace-write, danger-full-access"
  ],
